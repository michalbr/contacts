<%= form_with model: label, class: "space-y-4" do |form| %>
  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
    <%= field_error(@label, :name) %>
  </div>

  <div class="flex gap-2">
    <%= form.submit class: "rounded-lg bg-gray-800 px-5 py-2 text-sm font-medium text-white hover:bg-gray-700" %>
    <%= link_to "Cancel", "#", onclick: "this.closest('turbo-frame').innerHTML = ''", class: "inline-block rounded-lg border border-gray-300 px-5 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100" %>
  </div>
<% end %>
