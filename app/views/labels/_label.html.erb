<li class="group flex items-center justify-between rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700">
  <%= link_to contacts_path(label_id: label), class: "flex-1 truncate" do %>
    <%= label.name %>
  <% end %>

  <div class="invisible flex items-center gap-1 group-hover:visible">
    <%= link_to edit_label_path(label), data: { turbo_frame: "modal" }, class: "text-gray-400 hover:text-gray-600" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 20 20" fill="currentColor">
        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
      </svg>
    <% end %>

    <%= button_to "#", method: :delete,
        data: { confirm_modal_resource_name_param: label.name,
                confirm_modal_resource_path_param: label_path(label), 
                confirm_modal_resource_param: "Label",
                action: "click->confirm-modal#open",
                testid: "delete-label-button" },
        class: "text-gray-400 hover:text-red-500 cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
    <% end %>
  </div>
</li>