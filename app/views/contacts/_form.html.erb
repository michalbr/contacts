<%= form_with model: contact, class: "space-y-4" do |form| %>
  <div>
    <%= form.label :first_name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :first_name, class: "mt-1 block max-w-140 w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
    <%= field_error(@contact, :first_name) %>
  </div>

  <div>
    <%= form.label :last_name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :last_name, class: "mt-1 block max-w-140 w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
    <%= field_error(@contact, :last_name) %>
  </div>

  <div>
    <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
    <%= form.email_field :email, class: "mt-1 block max-w-140 w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
  </div>

  <div>
    <%= form.label :note, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :note, rows: 4, class: "mt-1 block max-w-140 w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
  </div>

  <div>
    <%= form.label :label_ids, "Labels", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1 flex flex-col gap-2">
      <% if Label.all.empty? %>
        <p>No lablels found.</p>
      <% end %>

      <%= form.collection_check_boxes :label_ids, Label.order(:name), :id, :name do |b| %>
        <label class="flex items-center gap-2 text-sm text-gray-700">
          <%= b.check_box class: "rounded border-gray-300" %>
          <%= b.label %>
        </label>
      <% end %>
    </div>
  </div>

  <%= form.submit class: "rounded-lg bg-gray-800 px-5 py-2 text-sm font-medium text-white hover:bg-gray-700" %>
  <%= link_to "Cancel", contacts_path, class: "inline-block rounded-lg border border-gray-300 px-5 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100" %>
<% end %>