<%= link_to "← Back to contacts", contacts_path, class: "text-sm text-gray-500 hover:text-gray-700" %>

<div class="flex items-center gap-3 mt-4 mb-6">
  <h1 class="text-3xl font-bold text-gray-900">
    <%= @contact.first_name %> <%= @contact.last_name %>
  </h1>

  <%= link_to edit_contact_path(@contact), class: "text-gray-400 hover:text-gray-600" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 20 20" fill="currentColor">
      <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
    </svg>
  <% end %>

  <%= button_to "#", method: :delete,
      data: { confirm_modal_resource_name_param: "#{@contact.first_name} #{@contact.last_name}",
              confirm_modal_resource_path_param: contact_path(@contact),
              confirm_modal_resource_param: "Contact",
              action: "click->confirm-modal#open",
              testid: "delete-contact-button" },
      class: "text-gray-400 hover:text-red-500 cursor-pointer" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
    </svg>
  <% end %>
</div>

<p class="text-gray-700 mb-3">
  <strong>Email:</strong>
  <%= @contact.email.present? ? mail_to(@contact.email) : "—" %>
</p>

<p class="text-gray-700 mb-3">
  <strong>Notes:</strong>
  <%= @contact.note.present? ? @contact.note : "—" %>
</p>

<p class="text-gray-700">
  <strong>Labels:</strong>
  <%= @contact.labels.present? ? @contact.labels.map { |label| label.name }.join(", ") : "—" %>
</p>
